async function predict() {
    const h = document.getElementById('humidity').value;
    const p = document.getElementById('pressure').value;
    const w = document.getElementById('wind').value;
    const resultDiv = document.getElementById('result');

    resultDiv.innerText = "Processing...";
    resultDiv.style.color = "white";

    try {
        const response = await fetch('/predict', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ humidity: h, pressure: p, wind: w })
        });

        const data = await response.json();

        if (data.status === "success") {
            const temp = data.prediction;
            resultDiv.innerText = `Prediction: ${temp}°C`;
            resultDiv.style.color = "#00ffcc";

            // --- DYNAMIC BACKGROUND COLORS ---
            if (temp < 10) document.body.style.background = "linear-gradient(135deg, #1e3c72, #2a5298)";
            else if (temp < 25) document.body.style.background = "linear-gradient(135deg, #11998e, #38ef7d)";
            else document.body.style.background = "linear-gradient(135deg, #ff512f, #dd2476)";

            // --- UPDATE HISTORY ---
            const list = document.getElementById('history-list');
            const item = document.createElement('li');
            item.innerHTML = `<strong>${temp}°C</strong> <small>(H:${h}%, P:${p})</small>`;
            if (list.children[0]?.innerText === "No data yet...") list.innerHTML = "";
            list.insertBefore(item, list.firstChild);

        } else {
            resultDiv.innerText = "Error: " + data.message;
            resultDiv.style.color = "#ff4d4d";
        }
    } catch (err) {
        resultDiv.innerText = "Connection failed!";
        resultDiv.style.color = "#ff4d4d";
    }
}

